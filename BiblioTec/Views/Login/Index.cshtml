@{
    ViewData["Title"] = "Iniciar Sesión";
    Layout = "_Layout";
}

<style>
    header, footer {
        display: none !important;
    }

    .container {
        max-width: 100% !important;
        padding: 0 !important;
    }

    main.pb-3 {
        padding: 0 !important;
    }

    :root {
        --green-deep: #1a3c34;
        --green-mid: #2d6a4f;
        --green-pale: #b7e4c7;
        --cream: #faf8f0;
        --gold: #c9a84c;
        --red-soft: #c0392b;
        --text-mid: #555;
        --text-light: #888;
        --radius-sm: 8px;
    }

    body {
        font-family: 'DM Sans', sans-serif;
    }

    .login-wrapper {
        display: flex;
        min-height: 100vh;
        margin: -1rem;
        animation: fadeIn .5s ease;
    }

    .login-left {
        flex: 1;
        background: var(--green-deep);
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }

        .login-left::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse at 20% 80%, rgba(45,106,79,.4) 0%, transparent 60%), radial-gradient(ellipse at 80% 20%, rgba(201,168,76,.15) 0%, transparent 50%);
            pointer-events: none;
        }

        .login-left .brand {
            position: relative;
            z-index: 1;
            text-align: center;
        }

        .login-left .brand-icon {
            width: 72px;
            height: 72px;
            background: var(--gold);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 2rem;
            color: var(--green-deep);
            box-shadow: 0 4px 20px rgba(201,168,76,.35);
        }

        .login-left h1 {
            font-family: 'DM Serif Display', serif;
            font-size: 2.8rem;
            color: #fff;
            letter-spacing: -0.5px;
            margin-bottom: .5rem;
        }

        .login-left p {
            color: var(--green-pale);
            font-size: 1.05rem;
            opacity: .85;
        }

    .login-decoration {
        position: absolute;
        bottom: -60px;
        right: -60px;
        width: 280px;
        height: 280px;
        border: 2px solid rgba(255,255,255,.06);
        border-radius: 50%;
        z-index: 0;
    }

        .login-decoration:nth-child(3) {
            width: 180px;
            height: 180px;
            bottom: auto;
            right: auto;
            top: -40px;
            left: -40px;
        }

    .login-right {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 3rem;
        background: var(--cream);
    }

    .login-form-wrapper {
        width: 100%;
        max-width: 400px;
    }

        .login-form-wrapper h2 {
            font-family: 'DM Serif Display', serif;
            font-size: 1.8rem;
            margin-bottom: .4rem;
            color: var(--green-deep);
        }

        .login-form-wrapper .subtitle {
            color: var(--text-light);
            margin-bottom: 2rem;
            font-size: .95rem;
        }

    .form-group {
        margin-bottom: 1.25rem;
    }

        .form-group label {
            display: block;
            font-size: .85rem;
            font-weight: 600;
            color: var(--text-mid);
            margin-bottom: .4rem;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .form-group input {
            width: 100%;
            padding: .85rem 1rem;
            border: 2px solid #ddd;
            border-radius: var(--radius-sm);
            font-size: 1rem;
            font-family: inherit;
            background: #fff;
            transition: border-color .2s, box-shadow .2s;
            outline: none;
        }

            .form-group input:focus {
                border-color: var(--green-mid);
                box-shadow: 0 0 0 3px rgba(45,106,79,.12);
            }

    .btn-login {
        width: 100%;
        padding: .95rem;
        background: var(--green-deep);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        font-size: 1rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        transition: background .2s, transform .1s;
        margin-top: .5rem;
    }

        .btn-login:hover {
            background: var(--green-mid);
        }

        .btn-login:active {
            transform: scale(.98);
        }

    .login-error {
        background: #fdecea;
        color: var(--red-soft);
        padding: .75rem 1rem;
        border-radius: var(--radius-sm);
        font-size: .9rem;
        margin-bottom: 1rem;
        border-left: 3px solid var(--red-soft);
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@media (max-width: 768px) {
        .login-wrapper {
            flex-direction: column;
        }

        .login-left {
            padding: 2rem;
            min-height: auto;
        }

            .login-left h1 {
                font-size: 2rem;
            }

        .login-right {
            padding: 2rem;
        }
    }

    @@media (max-width: 480px) {
        .login-left {
            display: none;
        }
    }
</style>

<link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">

<div class="login-wrapper">
    <div class="login-left">
        <div class="brand">
            <div class="brand-icon">📚</div>
            <h1>BiblioTec</h1>
            <p>Tu biblioteca digital</p>
        </div>
        <div class="login-decoration"></div>
        <div class="login-decoration"></div>
    </div>
    <div class="login-right">
        <div class="login-form-wrapper">
            <h2>Iniciar Sesión</h2>
            <p class="subtitle">Ingresa tus credenciales para acceder al lector</p>

            @if (ViewBag.Error != null)
            {
                <div class="login-error">@ViewBag.Error</div>
            }

            <form method="post" asp-controller="Login" asp-action="Index">
                <div class="form-group">
                    <label for="Correo">Correo electrónico</label>
                    <input type="email" name="Correo" id="Correo" placeholder="tu@correo.com" autocomplete="email" required />
                </div>
                <div class="form-group">
                    <label for="Password">Contraseña</label>
                    <input type="password" name="Password" id="Password" placeholder="••••••••" autocomplete="current-password" required />
                </div>
                <button type="submit" class="btn-login">Iniciar Sesión</button>
            </form>
        </div>
    </div>
</div>
