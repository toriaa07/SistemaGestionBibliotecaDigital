@using BiblioTec.DTOs
@using BiblioTec.DTOs.Prestamos
@model IEnumerable<BiblioTec.DTOs.Prestamos.PrestamoResumenDto>
@{
    Layout = null;
    var userName = ViewBag.UserName as string ?? "—";
    var userRole = ViewBag.UserRole as string ?? "—";
    var activos = Model.Where(p => p.Estado == "ACTIVO" || p.Estado == "VENCIDO").ToList();
    var vencidos = activos.Where(p => p.Estado == "VENCIDO").ToList();
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>BiblioTec — Mis Préstamos</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --green-deep: #1a3c34;
            --green-mid: #2d6a4f;
            --green-light: #40916c;
            --green-pale: #b7e4c7;
            --cream: #faf8f0;
            --gold: #c9a84c;
            --gold-light: #e8d593;
            --red-soft: #c0392b;
            --red-hover: #a93226;
            --text-dark: #1a1a1a;
            --text-mid: #555;
            --text-light: #888;
            --shadow-md: 0 4px 16px rgba(0,0,0,.1);
            --shadow-lg: 0 8px 32px rgba(0,0,0,.15);
            --radius: 12px;
            --radius-sm: 8px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--text-dark);
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* TOPBAR */
        .topbar {
            background: var(--green-deep);
            padding: 1rem 2rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: var(--shadow-md);
        }

        .topbar-brand {
            display: flex;
            align-items: center;
            gap: .75rem;
        }

            .topbar-brand .icon {
                width: 38px;
                height: 38px;
                background: var(--gold);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.1rem;
                color: var(--green-deep);
            }

            .topbar-brand span {
                font-family: 'DM Serif Display', serif;
                font-size: 1.3rem;
                color: #fff;
            }

        .topbar-user {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

            .topbar-user .user-info {
                text-align: right;
                color: #fff;
            }

                .topbar-user .user-info .name {
                    font-weight: 600;
                    font-size: .95rem;
                }

                .topbar-user .user-info .role {
                    font-size: .75rem;
                    color: var(--green-pale);
                    text-transform: uppercase;
                    letter-spacing: .5px;
                }

        .btn-logout {
            padding: .55rem 1.1rem;
            background: rgba(255,255,255,.1);
            color: #fff;
            border: 1px solid rgba(255,255,255,.2);
            border-radius: var(--radius-sm);
            font-size: .85rem;
            font-family: inherit;
            cursor: pointer;
            transition: background .2s;
            text-decoration: none;
        }

            .btn-logout:hover {
                background: rgba(255,255,255,.2);
            }

        /* DASHBOARD */
        .dashboard-content {
            max-width: 1100px;
            margin: 0 auto;
            padding: 2.5rem 2rem;
        }

        .dashboard-header {
            margin-bottom: 2rem;
        }

            .dashboard-header h2 {
                font-family: 'DM Serif Display', serif;
                font-size: 1.8rem;
                color: var(--green-deep);
                margin-bottom: .3rem;
            }

            .dashboard-header p {
                color: var(--text-light);
                font-size: .95rem;
            }

        .stats-bar {
            display: flex;
            gap: 1rem;
            margin-bottom: 2rem;
            flex-wrap: wrap;
        }

        .stat-chip {
            background: #fff;
            border: 1px solid #e8e4da;
            border-radius: 50px;
            padding: .5rem 1.2rem;
            font-size: .85rem;
            font-weight: 500;
            color: var(--text-mid);
            display: flex;
            align-items: center;
            gap: .4rem;
        }

            .stat-chip .dot {
                width: 8px;
                height: 8px;
                border-radius: 50%;
                display: inline-block;
            }

        .dot-active {
            background: var(--green-light);
        }

        .dot-overdue {
            background: var(--red-soft);
        }

        /* TOAST */
        .toast {
            padding: .85rem 1.2rem;
            border-radius: var(--radius-sm);
            font-size: .9rem;
            font-weight: 500;
            margin-bottom: 1.5rem;
        }

        .toast-success {
            background: rgba(45,106,79,.1);
            color: var(--green-mid);
            border-left: 3px solid var(--green-mid);
        }

        .toast-error {
            background: #fdecea;
            color: var(--red-soft);
            border-left: 3px solid var(--red-soft);
        }

        /* BOOK CARDS */
        .books-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 1.25rem;
        }

        .book-card {
            background: #fff;
            border-radius: var(--radius);
            border: 1px solid #e8e4da;
            padding: 1.5rem;
            transition: box-shadow .25s, transform .25s;
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
            animation: slideUp .4s ease backwards;
        }

            .book-card::before {
                content: '';
                position: absolute;
                top: 0;
                left: 0;
                width: 4px;
                height: 100%;
                background: var(--green-mid);
                border-radius: 4px 0 0 4px;
            }

            .book-card.vencido::before {
                background: var(--red-soft);
            }

            .book-card:hover {
                box-shadow: var(--shadow-md);
                transform: translateY(-2px);
            }

            .book-card .book-title {
                font-family: 'DM Serif Display', serif;
                font-size: 1.15rem;
                color: var(--green-deep);
                margin-bottom: .3rem;
                line-height: 1.3;
            }

            .book-card .book-author {
                font-size: .88rem;
                color: var(--text-light);
                margin-bottom: 1rem;
            }

        .book-meta {
            display: flex;
            flex-direction: column;
            gap: .4rem;
            margin-bottom: 1.25rem;
            flex-grow: 1;
        }

        .book-meta-item {
            font-size: .82rem;
            color: var(--text-mid);
            display: flex;
            align-items: center;
            gap: .4rem;
        }

            .book-meta-item .meta-icon {
                width: 16px;
                text-align: center;
                flex-shrink: 0;
            }

        .badge {
            display: inline-block;
            padding: .25rem .7rem;
            border-radius: 50px;
            font-size: .75rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .3px;
        }

        .badge-activo {
            background: rgba(45,106,79,.1);
            color: var(--green-mid);
        }

        .badge-vencido {
            background: rgba(192,57,43,.1);
            color: var(--red-soft);
        }

        .book-actions {
            display: flex;
            gap: .6rem;
        }

        .btn-read {
            flex: 1;
            padding: .7rem 1rem;
            background: var(--green-deep);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            font-size: .88rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: background .2s, transform .1s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: .4rem;
        }

            .btn-read:hover {
                background: var(--green-mid);
            }

            .btn-read:active {
                transform: scale(.97);
            }

        .btn-devolver {
            padding: .7rem 1rem;
            background: #fff;
            color: var(--red-soft);
            border: 2px solid var(--red-soft);
            border-radius: var(--radius-sm);
            font-size: .88rem;
            font-weight: 600;
            font-family: inherit;
            cursor: pointer;
            transition: all .2s;
        }

            .btn-devolver:hover {
                background: var(--red-soft);
                color: #fff;
            }

        /* EMPTY STATE */
        .empty-state {
            text-align: center;
            padding: 4rem 2rem;
            grid-column: 1 / -1;
        }

            .empty-state .empty-icon {
                font-size: 3.5rem;
                margin-bottom: 1rem;
                opacity: .4;
            }

            .empty-state h3 {
                font-family: 'DM Serif Display', serif;
                font-size: 1.4rem;
                color: var(--text-mid);
                margin-bottom: .5rem;
            }

            .empty-state p {
                color: var(--text-light);
                font-size: .95rem;
            }

        /* PDF READER OVERLAY */
        #readerOverlay {
            display: none;
            position: fixed;
            inset: 0;
            z-index: 1000;
            background: #1a1a1a;
        }

            #readerOverlay.active {
                display: block;
            }

        .reader-topbar {
            background: var(--green-deep);
            padding: .75rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid rgba(255,255,255,.1);
        }

        .reader-topbar-left {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .btn-back {
            padding: .5rem 1rem;
            background: rgba(255,255,255,.1);
            color: #fff;
            border: 1px solid rgba(255,255,255,.15);
            border-radius: var(--radius-sm);
            font-size: .85rem;
            font-family: inherit;
            cursor: pointer;
            transition: background .2s;
            display: flex;
            align-items: center;
            gap: .4rem;
        }

            .btn-back:hover {
                background: rgba(255,255,255,.2);
            }

        .reader-title {
            color: #fff;
            font-family: 'DM Serif Display', serif;
            font-size: 1.05rem;
            max-width: 500px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .reader-warning {
            color: var(--gold-light);
            font-size: .78rem;
            display: flex;
            align-items: center;
            gap: .3rem;
        }

        .reader-body {
            height: calc(100vh - 52px);
            position: relative;
            background: #2a2a2a;
        }

            .reader-body iframe {
                width: 100%;
                height: 100%;
                border: none;
            }

        /* MODAL DEVOLVER */
        .modal-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0,0,0,.5);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }

            .modal-overlay.active {
                display: flex;
            }

        .modal-box {
            background: #fff;
            border-radius: var(--radius);
            padding: 2rem;
            max-width: 420px;
            width: 90%;
            box-shadow: var(--shadow-lg);
            text-align: center;
        }

            .modal-box .modal-icon {
                font-size: 2.5rem;
                margin-bottom: .75rem;
            }

            .modal-box h3 {
                font-family: 'DM Serif Display', serif;
                font-size: 1.3rem;
                color: var(--green-deep);
                margin-bottom: .4rem;
            }

            .modal-box p {
                color: var(--text-mid);
                font-size: .92rem;
                margin-bottom: 1.5rem;
                line-height: 1.5;
            }

        .modal-actions {
            display: flex;
            gap: .75rem;
            justify-content: center;
        }

        .btn-modal-cancel {
            padding: .65rem 1.5rem;
            background: #f5f5f5;
            color: var(--text-mid);
            border: none;
            border-radius: var(--radius-sm);
            font-family: inherit;
            font-size: .9rem;
            font-weight: 500;
            cursor: pointer;
            transition: background .2s;
            text-decoration: none;
            display: inline-block;
        }

            .btn-modal-cancel:hover {
                background: #eee;
            }

        .btn-modal-confirm {
            padding: .65rem 1.5rem;
            background: var(--red-soft);
            color: #fff;
            border: none;
            border-radius: var(--radius-sm);
            font-family: inherit;
            font-size: .9rem;
            font-weight: 600;
            cursor: pointer;
            transition: background .2s;
        }

            .btn-modal-confirm:hover {
                background: var(--red-hover);
            }

        @@keyframes slideUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .book-card:nth-child(1) {
            animation-delay: .05s;
        }

        .book-card:nth-child(2) {
            animation-delay: .1s;
        }

        .book-card:nth-child(3) {
            animation-delay: .15s;
        }

        .book-card:nth-child(4) {
            animation-delay: .2s;
        }

        .book-card:nth-child(5) {
            animation-delay: .25s;
        }

        .book-card:nth-child(6) {
            animation-delay: .3s;
        }

        @@media (max-width: 768px) {
            .topbar {
                padding: .75rem 1rem;
            }

            .topbar-brand span {
                display: none;
            }

            .dashboard-content {
                padding: 1.5rem 1rem;
            }

            .books-grid {
                grid-template-columns: 1fr;
            }

            .reader-title {
                max-width: 180px;
                font-size: .9rem;
            }

            .reader-warning {
                display: none;
            }
        }

        @@media (max-width: 480px) {
            .book-actions {
                flex-direction: column;
            }

            .stats-bar {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

    <!-- TOPBAR -->
    <div class="topbar">
        <div class="topbar-brand">
            <div class="icon">📚</div>
            <span>BiblioTec</span>
        </div>
        <div class="topbar-user">
            <div class="user-info">
                <div class="name">@userName</div>
                <div class="role">@userRole</div>
            </div>
            <a class="btn-logout" asp-controller="Login" asp-action="Logout">Cerrar sesión</a>
        </div>
    </div>

    <!-- DASHBOARD -->
    <div class="dashboard-content">
        <div class="dashboard-header">
            <h2>Mis Préstamos</h2>
            <p>Libros que actualmente tienes en préstamo</p>
        </div>

        <!-- TOASTS (TempData) -->
        @if (TempData["Success"] != null)
        {
            <div class="toast toast-success">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="toast toast-error">@TempData["Error"]</div>
        }

        <!-- STATS -->
        <div class="stats-bar">
            <div class="stat-chip">
                <span class="dot dot-active"></span>
                @activos.Count préstamo@(activos.Count != 1 ? "s" : "") activo@(activos.Count != 1 ? "s" : "")
            </div>
            @if (vencidos.Count > 0)
            {
                <div class="stat-chip">
                    <span class="dot dot-overdue"></span>
                    @vencidos.Count vencido@(vencidos.Count != 1 ? "s" : "")
                </div>
            }
        </div>

        <!-- TARJETAS -->
        <div class="books-grid">
            @if (activos.Count == 0)
            {
                <div class="empty-state">
                    <div class="empty-icon">📚</div>
                    <h3>Sin préstamos activos</h3>
                    <p>Actualmente no tienes libros en préstamo. Solicita uno para comenzar a leer.</p>
                </div>
            }
            else
            {
                @foreach (var p in activos)
                {
                    var isVencido = p.Estado == "VENCIDO";
                    var fechaVenc = p.FechaVencimiento;
                    var diasRestantes = (int)Math.Ceiling((fechaVenc - DateTime.Now).TotalDays);
                    var estadoTexto = isVencido ? "Vencido"
                    : diasRestantes <= 2 ? $"Vence en {diasRestantes} día{(diasRestantes != 1 ? "s" : "")}"
                    : $"{diasRestantes} días restantes";

                    <div class="book-card @(isVencido ? "vencido" : "")">
                        <div class="book-title">@p.TituloLibro</div>
                        <div class="book-author">@(string.IsNullOrEmpty(p.AutorLibro) ? "Autor desconocido" : p.AutorLibro)</div>
                        <div class="book-meta">
                            <div class="book-meta-item">
                                <span class="meta-icon">📅</span>Prestado: @p.FechaPrestamo.ToString("dd MMM yyyy")
                            </div>
                            <div class="book-meta-item">
                                <span class="meta-icon">⏰</span>Vence: @p.FechaVencimiento.ToString("dd MMM yyyy")
                            </div>
                            <div class="book-meta-item">
                                <span class="meta-icon">@(isVencido ? "🔴" : "🟢")</span>
                                <span class="badge @(isVencido ? "badge-vencido" : "badge-activo")">@estadoTexto</span>
                            </div>
                        </div>
                        <div class="book-actions">
                            @if (!string.IsNullOrEmpty(p.RutaPdf))
                            {
                                <button class="btn-read" onclick="openReader('@Html.Raw(p.RutaPdf.Replace("'", "\\'"))', '@Html.Raw(p.TituloLibro.Replace("'", "\\'"))')">📖 Leer</button>
                            }
                            <button class="btn-devolver" onclick="openReturnModal(@p.PrestamoId, '@Html.Raw(p.TituloLibro.Replace("'", "\\'"))')">Devolver</button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- PDF READER OVERLAY (requiere JS mínimo para el iframe) -->
    <section id="readerOverlay" oncontextmenu="return false;">
        <div class="reader-topbar">
            <div class="reader-topbar-left">
                <button class="btn-back" onclick="closeReader()">← Volver</button>
                <span class="reader-title" id="readerTitle">—</span>
            </div>
            <div class="reader-warning">🔒 Modo lectura — descarga no disponible</div>
        </div>
        <div class="reader-body">
            @foreach (var prestamo in Model)
            {
                <div class="reader-body">
                    <iframe src="@prestamo.RutaPdf" width="100%" height="800"></iframe>
                </div>
            }
        </div>
    </section>

    <!-- MODAL DEVOLVER -->
    <div class="modal-overlay" id="returnModal">
        <div class="modal-box">
            <div class="modal-icon">📖</div>
            <h3>¿Devolver este libro?</h3>
            <p id="returnModalText"></p>
            <div class="modal-actions">
                <button class="btn-modal-cancel" onclick="closeReturnModal()">Cancelar</button>
                <form id="returnForm" method="post" asp-controller="LectorPDF" asp-action="Devolver" style="display:inline;">
                    <input type="hidden" name="id" id="returnIdInput" />
                    <button type="submit" class="btn-modal-confirm">Sí, devolver</button>
                </form>
            </div>
        </div>
    </div>

    <!-- JS mínimo: solo para abrir/cerrar el iframe del lector y el modal -->
    <script>
        function openReader(url, titulo) {
            document.getElementById('readerTitle').textContent = titulo;
            var pdfUrl = url;
            if (pdfUrl.includes('sharepoint.com') && !pdfUrl.includes('action=embedview')) {
                pdfUrl += (pdfUrl.includes('?') ? '&' : '?') + 'action=embedview';
            }
            document.getElementById('pdfFrame').src = pdfUrl;
            document.getElementById('readerOverlay').classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeReader() {
            document.getElementById('pdfFrame').src = 'about:blank';
            document.getElementById('readerOverlay').classList.remove('active');
            document.body.style.overflow = '';
        }

        function openReturnModal(id, titulo) {
            document.getElementById('returnIdInput').value = id;
            document.getElementById('returnModalText').textContent =
                '¿Estás seguro de que deseas devolver "' + titulo + '"? Ya no podrás acceder a su lectura.';
            document.getElementById('returnModal').classList.add('active');
        }

        function closeReturnModal() {
            document.getElementById('returnModal').classList.remove('active');
        }

        document.getElementById('returnModal').addEventListener('click', function (e) {
            if (e.target === e.currentTarget) closeReturnModal();
        });

        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { closeReader(); closeReturnModal(); }
        });
    </script>
</body>
</html>
