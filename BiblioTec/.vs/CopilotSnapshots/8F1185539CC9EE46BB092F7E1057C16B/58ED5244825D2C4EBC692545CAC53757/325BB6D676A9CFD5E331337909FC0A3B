using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using System.Security.Claims;
using BiblioTec.DTOs.Prestamos;
using BiblioTec.Services.Interfaces;

namespace BiblioTec.Controllers
{
    [ApiController]
    [Route("api/prestamos")]
    [Authorize]
    public class PrestamosController : ControllerBase
    {
        private readonly IPrestamoService _prestamoService;

        public PrestamosController(IPrestamoService prestamoService)
        {
            _prestamoService = prestamoService;
        }

        // GET api/prestamos  (solo ADMIN)
        [HttpGet]
        [Authorize(Roles = "ADMIN")]
        public async Task<IActionResult> GetAll([FromQuery] int? idUsuario = null, [FromQuery] string? estado = null, [FromQuery] int? idLibro = null, [FromQuery] bool? activos = null)
        {
            var prestamos = await _prestamoService.GetAllAsync();

            // Aplicar filtros
            if (idUsuario.HasValue)
                prestamos = prestamos.Where(p => p.IdUsuario == idUsuario.Value).ToList();

            if (!string.IsNullOrEmpty(estado))
                prestamos = prestamos.Where(p => p.Estado.Equals(estado, StringComparison.OrdinalIgnoreCase)).ToList();

            if (idLibro.HasValue)
                prestamos = prestamos.Where(p => p.IdLibro == idLibro.Value).ToList();

            if (activos.HasValue)
                prestamos = activos.Value ? 
                    prestamos.Where(p => p.FechaDevolucion == null).ToList() : 
                    prestamos.Where(p => p.FechaDevolucion != null).ToList();

            return Ok(new { success = true, data = prestamos });
        }

        // GET api/prestamos/{id}
        [HttpGet("{id}")]
        public async Task<IActionResult> GetById(int id)
        {
            try
            {
                var prestamo = await _prestamoService.GetByIdAsync(id);
                return Ok(new { success = true, data = prestamo });
            }
            catch (KeyNotFoundException ex)
            {
                return NotFound(new { success = false, message = ex.Message });
            }
        }

        // GET api/prestamos/mis-prestamos  (usuario autenticado)
        [HttpGet("mis-prestamos")]
        public async Task<IActionResult> GetMisPrestamos()
        {
            var idUsuario = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!);
            var prestamos = await _prestamoService.GetByUsuarioAsync(idUsuario);
            return Ok(new { success = true, data = prestamos });
        }

        // GET api/prestamos/usuario/{idUsuario}  (solo ADMIN)
        [HttpGet("usuario/{idUsuario}")]
        [Authorize(Roles = "ADMIN")]
        public async Task<IActionResult> GetByUsuario(int idUsuario)
        {
            var prestamos = await _prestamoService.GetByUsuarioAsync(idUsuario);
            return Ok(new { success = true, data = prestamos });
        }

        // POST api/prestamos
        [HttpPost]
        public async Task<IActionResult> Crear(PrestamoCreateDto dto)
        {
            try
            {
                var idUsuario = int.Parse(User.FindFirstValue(ClaimTypes.NameIdentifier)!);
                var prestamo = await _prestamoService.CrearAsync(dto, idUsuario);
                return CreatedAtAction(nameof(GetById), new { id = prestamo.IdPrestamo },
                    new { success = true, data = prestamo });
            }
            catch (KeyNotFoundException ex)
            {
                return NotFound(new { success = false, message = ex.Message });
            }
            catch (InvalidOperationException ex)
            {
                return BadRequest(new { success = false, message = ex.Message });
            }
        }

        // PATCH api/prestamos/{id}/devolver
        [HttpPatch("{id}/devolver")]
        public async Task<IActionResult> Devolver(int id)
        {
            try
            {
                await _prestamoService.DevolverAsync(id);
                return Ok(new { success = true, message = "Libro devuelto correctamente." });
            }
            catch (KeyNotFoundException ex)
            {
                return NotFound(new { success = false, message = ex.Message });
            }
            catch (InvalidOperationException ex)
            {
                return BadRequest(new { success = false, message = ex.Message });
            }
        }

        // PATCH api/prestamos/vencidos  (solo ADMIN, para marcar manualmente)
        [HttpPatch("vencidos")]
        [Authorize(Roles = "ADMIN")]
        public async Task<IActionResult> MarcarVencidos()
        {
            await _prestamoService.MarcarVencidosAsync();
            return Ok(new { success = true, message = "Préstamos vencidos actualizados." });
        }
    }
}
