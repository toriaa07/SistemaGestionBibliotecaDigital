<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.shape.*?>

<HBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.bibliotec.controller.LoginController"
      styleClass="root-pane"
      prefWidth="900" prefHeight="600">

    <!-- Panel izquierdo decorativo -->
    <VBox styleClass="login-left-panel" HBox.hgrow="ALWAYS" prefWidth="420">
        <alignment>CENTER</alignment>
        <VBox alignment="CENTER" spacing="16">
            <Label text="📚" style="-fx-font-size: 72px;"/>
            <Label text="BiblioTec" styleClass="app-brand"/>
            <Label text="Sistema de Gestión de Biblioteca Digital"
                   styleClass="brand-subtitle" wrapText="true" textAlignment="CENTER"/>
            <Separator prefWidth="200" style="-fx-background-color: rgba(255,255,255,0.3);"/>
            <Label text="Colegio Padre Arrupe" styleClass="brand-school"/>
        </VBox>
    </VBox>

    <!-- Panel derecho: formulario -->
    <VBox styleClass="login-right-panel" prefWidth="480" alignment="CENTER" spacing="0">
        <padding><Insets top="60" right="60" bottom="60" left="60"/></padding>

        <Label text="Iniciar Sesión" styleClass="login-title"/>
        <Label text="Ingresa tus credenciales para continuar" styleClass="login-subtitle"/>

        <VBox spacing="6" style="-fx-padding: 30 0 0 0;">
            <Label text="Correo electrónico" styleClass="field-label"/>
            <TextField fx:id="correoField" styleClass="text-field-custom"
                       promptText="usuario@ejemplo.com"/>
        </VBox>

        <VBox spacing="6" style="-fx-padding: 18 0 0 0;">
            <Label text="Contraseña" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" styleClass="text-field-custom"
                           promptText="••••••••"/>
        </VBox>

        <Label fx:id="errorLabel" styleClass="error-label" wrapText="true"
               style="-fx-padding: 10 0 0 0;" visible="false" managed="false"/>

        <Button fx:id="loginBtn" text="Ingresar" styleClass="btn-primary"
                prefWidth="360" prefHeight="46"
                style="-fx-padding: 0; -fx-margin-top: 28px;"
                onAction="#handleLogin"
                defaultButton="true">
            <VBox.margin><Insets top="28"/></VBox.margin>
        </Button>

        <Label text="¿No tienes cuenta? Regístrate con un administrador"
               styleClass="helper-text" style="-fx-padding: 20 0 0 0;"/>

    </VBox>
</HBox>
